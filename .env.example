# Optional: Anthropic API key — ONLY needed for the standalone Python digest
# tool (API credits). The default pipeline runs entirely on your Claude Code
# subscription (the subagents digest in-context), so you can leave this blank.
ANTHROPIC_API_KEY=

# Optional: Semantic Scholar API key (higher rate limits; works without it)
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Optional but recommended: GitHub token for the 'github' awesome-list source
# (raises the GitHub API rate limit from 60/hr to 5000/hr).
GITHUB_TOKEN=

# Optional: a contact email improves OpenAlex / arXiv politeness rate limits
CONTACT_EMAIL=
